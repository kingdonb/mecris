{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "mecris": {
      "command": "uv",
      "args": [
        "--quiet",
        "run",
        "--project", ".",
        "mcp_server.py",
        "--stdio"
      ],
      "env": {
        "PYTHONPATH": ".",
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
