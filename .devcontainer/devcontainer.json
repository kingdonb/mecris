{
  "name": "Mecris Development Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "ms-python.python",
        "ms-python.vscode-pylint",
        "tamasfe.even-better-toml",
        "fermyon.akita",
        "vscjava.vscode-java-pack"
      ]
    }
  },
  "postCreateCommand": "uv venv && . .venv/bin/activate && uv pip install -e . && playwright install --with-deps",
  "remoteUser": "root"
}
