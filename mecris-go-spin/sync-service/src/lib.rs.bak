async fn handle_heartbeat_post(req: Request) -> anyhow::Result<Response<String>> {
    let auth_header = req.headers().get("authorization");
    let user_id = match extract_user_id(auth_header).await {
        Some(id) => id,
        None => return Ok(text_response(401, "Unauthorized")?),
    };

    let body_bytes = req.into_body().collect().await.map_err(|e| anyhow::anyhow!("Body err: {:?}", e))?.to_bytes();
    let body: serde_json::Value = serde_json::from_slice(&body_bytes)?;
    
    let pid = body.get("process_id").and_then(|v| v.as_str()).unwrap_or("unknown");
    let role = body.get("role").and_then(|v| v.as_str()).unwrap_or("leader");

    let db_url = match variables::get("db_url").await {
        Ok(v) if !v.is_empty() => v,
        _ => variables::get("neon_db_url").await?,
    };
    let connection = Connection::open(&db_url).await?;
    
    let update_query = if role == "leader" {
        "INSERT INTO scheduler_election (user_id, role, process_id, heartbeat) \
         VALUES ($1, $2, $3, CURRENT_TIMESTAMP) \
         ON CONFLICT (user_id, role) DO UPDATE SET \
         heartbeat = EXCLUDED.heartbeat, process_id = EXCLUDED.process_id"
    } else {
        "INSERT INTO scheduler_election (user_id, role, process_id, heartbeat) \
         VALUES ($1, $2, $3, CURRENT_TIMESTAMP) \
         ON CONFLICT (user_id, role) DO UPDATE SET \
         heartbeat = EXCLUDED.heartbeat, process_id = EXCLUDED.process_id"
    };

    connection.execute(update_query, &[
        ParameterValue::Str(user_id.clone()),
        ParameterValue::Str(role.to_string()),
        ParameterValue::Str(pid.to_string()),
    ]).await?;

    let resp = StatusResponse { status: "success".to_string(), message: "Heartbeat received".to_string() };
    json_response(200, &resp)
}

