async fn handle_walks_post(req: Request) -> anyhow::Result<Response<String>> {
    let auth_header = req.headers().get("authorization");
    let user_id = match extract_user_id(auth_header).await {
        Some(id) => id,
        None => return Ok(text_response(401, "Unauthorized")?),
    };

    let body_bytes = req.into_body().collect().await.map_err(|e| anyhow::anyhow!("Body err: {:?}", e))?.to_bytes();
    let walk: WalkDataSummary = serde_json::from_slice(&body_bytes)?;

    let db_url = match variables::get("db_url").await {
        Ok(v) if !v.is_empty() => v,
        _ => variables::get("neon_db_url").await?,
    };
    let connection = Connection::open(&db_url).await?;

    let _ = connection.execute(
        "INSERT INTO users (pocket_id_sub, beeminder_token_encrypted, beeminder_goal) VALUES ($1, '', 'bike') ON CONFLICT DO NOTHING",
        &[ParameterValue::Str(user_id.clone())]
    ).await;

    let prev_distance_query = "SELECT distance_meters FROM walk_inferences WHERE user_id = $1 AND start_time = $2";
    let prev_rs = connection.query(prev_distance_query, &[
        ParameterValue::Str(user_id.clone()),
        ParameterValue::Str(walk.start_time.clone())
    ]).await?;
    let prev_rows = prev_rs.collect().await?;
    
    let previous_distance_str = if !prev_rows.is_empty() {
        match &prev_rows[0][0] {
            DbValue::Str(s) => s.clone(),
            _ => "0".to_string()
        }
    } else {
        "0".to_string()
    };
    
    let previous_distance: f64 = previous_distance_str.parse().unwrap_or(0.0);
    let delta_meters = walk.distance_meters - previous_distance;

    let upsert_query = "INSERT INTO walk_inferences (user_id, start_time, end_time, step_count, distance_meters, distance_source) \
                        VALUES ($1, $2, $3, $4, $5, $6) \
                        ON CONFLICT (user_id, start_time) DO UPDATE SET \
                        end_time = EXCLUDED.end_time, step_count = EXCLUDED.step_count, \
                        distance_meters = EXCLUDED.distance_meters, distance_source = EXCLUDED.distance_source";
    
    connection.execute(upsert_query, &[
        ParameterValue::Str(user_id.clone()),
        ParameterValue::Str(walk.start_time.clone()),
        ParameterValue::Str(walk.end_time.clone()),
        ParameterValue::Str(walk.step_count.to_string()),
        ParameterValue::Str(walk.distance_meters.to_string()),
        ParameterValue::Str(walk.distance_source.clone())
    ]).await?;

    let token_rs = connection.query(
        "SELECT beeminder_goal FROM users WHERE pocket_id_sub = $1",
        &[ParameterValue::Str(user_id.clone())]
    ).await?;
    let token_rows = token_rs.collect().await?;

    if !token_rows.is_empty() && delta_meters > 200.0 {
        let goal = match &token_rows[0][0] { DbValue::Str(s) if !s.is_empty() => s.clone(), _ => "bike".to_string() };
        let total_miles = walk.distance_meters / 1609.34;
        let rounded_miles = (total_miles * 1000.0).round() / 1000.0;
        let _ = push_to_beeminder(&user_id, &goal, rounded_miles, "Synced via Spin (Cumulative)", &connection).await;
    }

    let resp = StatusResponse { status: "success".to_string(), message: "Walk ingested".to_string() };
    json_response(201, &resp)
}

async fn handle_trigger_reminders_post(_req: Request) -> anyhow::Result<Response<String>> {
    let account_sid = match variables::get("twilio_account_sid").await {
        Ok(s) if !s.is_empty() => s,
        _ => return Ok(text_response(503, "twilio_account_sid not configured")?),
    };
    let auth_token_enc = match variables::get("twilio_auth_token_encrypted").await {
        Ok(s) if !s.is_empty() => s,
        _ => return Ok(text_response(503, "twilio_auth_token_encrypted not configured")?),
    };
    let auth_token = decrypt_token(&auth_token_enc).await?;
    let from_phone = match variables::get("twilio_from_number").await {
        Ok(s) if !s.is_empty() => s,
        _ => return Ok(text_response(503, "twilio_from_number not configured")?),
    };

    let db_url = match variables::get("db_url").await {
        Ok(v) if !v.is_empty() => v,
        _ => variables::get("neon_db_url").await?,
    };
    let connection = Connection::open(&db_url).await?;

    let query = "SELECT pocket_id_sub, phone_number_encrypted, COALESCE(timezone, 'UTC'), \
                 COALESCE(location_lat::TEXT, ''), COALESCE(location_lon::TEXT, ''), \
                 COALESCE(notification_prefs::TEXT, '{}') \
                 FROM users WHERE phone_number_encrypted IS NOT NULL AND phone_number_encrypted != '' \
                 AND autonomous_sync_enabled = true";
    let rs = connection.query(query, &[]).await?;
    let rows = rs.collect().await?;

    let now_utc = chrono::Utc::now();
    let today_utc = now_utc.format("%Y-%m-%d").to_string();
    let now_epoch_secs = now_utc.timestamp() as u64;

    let mut sent = 0;
    let mut errors = 0;

    for row in &rows {
        let user_id = match &row[0] { DbValue::Str(s) => s.clone(), _ => continue };
        let phone_enc = match &row[1] { DbValue::Str(s) => s.clone(), _ => continue };
        let timezone = match &row[2] { DbValue::Str(s) => s.clone(), _ => "UTC".to_string() };
        let prefs_json = match &row[5] { DbValue::Str(s) => s.clone(), _ => "{}".to_string() };
        let prefs: NotificationPrefs = serde_json::from_str(&prefs_json).unwrap_or_default();

        let local_hour = local_hour_from_timezone(&timezone, &now_utc);

        let step_rs = connection.query(
            "SELECT step_count FROM walk_inferences WHERE user_id = $1 AND start_time >= $2 ORDER BY start_time ASC",
            &[ParameterValue::Str(user_id.clone()), ParameterValue::Str(today_utc.clone())],
        ).await?;
        let step_rows = step_rs.collect().await?;
        let step_strings: Vec<String> = step_rows.iter().filter_map(|r| match &r[0] { DbValue::Str(s) => Some(s.clone()), _ => None }).collect();
        let step_count = aggregate_step_count(&step_strings);

        let msg_rs = connection.query(
            "SELECT sent_at::TEXT FROM message_log WHERE user_id = $1 AND type = 'walk_reminder' ORDER BY sent_at DESC LIMIT 1",
            &[ParameterValue::Str(user_id.clone())],
        ).await?;
        let msg_rows = msg_rs.collect().await?;
        let last_sent_at: Option<String> = msg_rows.first().and_then(|r| match &r[0] { DbValue::Str(s) if !s.is_empty() => Some(s.clone()), _ => None });
        let minutes_since_last = minutes_since_last_reminder(last_sent_at.as_deref(), now_epoch_secs);

        if !should_dispatch_reminder(local_hour, step_count, minutes_since_last, &prefs) {
            write_obs_status(&connection, &user_id, &cloud_role().await, "Stood down (conditions not met)", "Send Walk Reminder", None).await;
            continue;
        }

        let hb_rs = connection.query(
            "SELECT EXTRACT(EPOCH FROM (CURRENT_TIMESTAMP - heartbeat)) / 60 AS minutes_since \
             FROM scheduler_election WHERE user_id = $1 AND role = 'android_client' \
             ORDER BY heartbeat DESC LIMIT 1",
            &[ParameterValue::Str(user_id.clone())],
        ).await?;
        let hb_rows = hb_rs.collect().await?;
        let android_heartbeat_minutes: Option<u64> = hb_rows.first().and_then(|r| match &r[0] {
            DbValue::Floating64(f) => Some(*f as u64),
            DbValue::Str(s) => s.parse::<f64>().ok().map(|f| f as u64),
            _ => None,
        });

        if android_client_is_active(android_heartbeat_minutes) {
            let stand_down_status = format!("Stood down (Android client active {}min ago)", android_heartbeat_minutes.unwrap_or(0));
            write_obs_status(&connection, &user_id, &cloud_role().await, &stand_down_status, "Send Walk Reminder", None).await;
            continue;
        }

        let phone = decrypt_token(&phone_enc).await?;
        match send_twilio_sms(&account_sid, &auth_token, &from_phone, &phone, "Mecris: Time for a walk! Reply YES to log 1 mile.").await {
            Ok(_) => {
                let _ = connection.execute(
                    "INSERT INTO message_log (user_id, type, sent_at, compliance_status) VALUES ($1, 'walk_reminder', CURRENT_TIMESTAMP, 'sent')",
                    &[ParameterValue::Str(user_id.clone())]
                ).await;
                write_obs_status(&connection, &user_id, &cloud_role().await, "Sent Walk Reminder", "Send Walk Reminder", None).await;
                sent += 1;
            }
            Err(e) => {
                write_obs_status(&connection, &user_id, &cloud_role().await, "Reminder failed", "Send Walk Reminder", Some(&e.to_string())).await;
                errors += 1;
            }
        }
    }

    json_response(200, &format!("Sent {} reminders, {} errors", sent, errors))
}

async fn handle_failover_sync_post(_req: Request) -> anyhow::Result<Response<String>> {
    let db_url = match variables::get("db_url").await {
        Ok(v) if !v.is_empty() => v,
        _ => variables::get("neon_db_url").await?,
    };
    let connection = Connection::open(&db_url).await?;

    let query = "SELECT pocket_id_sub, EXTRACT(EPOCH FROM CURRENT_TIMESTAMP - COALESCE(last_autonomous_sync, '1970-01-01'::TIMESTAMPTZ))/60 AS mins_since \
                 FROM users WHERE autonomous_sync_enabled = true";
    let rs = connection.query(query, &[]).await?;
    let rows = rs.collect().await?;
    
    let mut success_count = 0;
    for row in &rows {
        let user_id = match &row[0] { DbValue::Str(s) => s.clone(), _ => continue };
        let mins_since = match &row[1] {
            DbValue::Floating64(f) => *f,
            DbValue::Str(s) => s.parse().unwrap_or(0.0),
            _ => 0.0
        };

        if mins_since > 1440.0 {
            if let Ok(_) = run_clozemaster_scraper(&db_url, &user_id).await {
                success_count += 1;
            }
        }
    }

    json_response(200, &format!("Failover sync completed for {} users", success_count))
}

async fn handle_request_phone_verification_post(req: Request) -> anyhow::Result<Response<String>> {
    let auth_header = req.headers().get("authorization");
    let user_id = match extract_user_id(auth_header).await {
        Some(id) => id,
        None => return Ok(text_response(401, "Unauthorized")?),
    };

    let body = req.into_body().collect().await.map_err(|e| anyhow::anyhow!("Body err: {:?}", e))?.to_bytes();
    #[derive(Deserialize)]
    struct VerificationRequest { phone_number: String }
    let verify_req: VerificationRequest = serde_json::from_slice(&body)?;
    
    let db_url = match variables::get("db_url").await {
        Ok(v) if !v.is_empty() => v,
        _ => variables::get("neon_db_url").await?,
    };
    let connection = Connection::open(&db_url).await?;

    let mut rand_bytes = [0u8; 4];
    use getrandom::getrandom;
    getrandom(&mut rand_bytes).map_err(|e| anyhow::anyhow!("getrandom failed: {}", e))?;
    let code = format!("{:06}", (u32::from_be_bytes(rand_bytes) % 1000000));
    let code_hash = hex::encode(Sha256::digest(code.as_bytes()));

    let expires_at = (chrono::Utc::now() + chrono::Duration::minutes(15)).to_rfc3339();
    
    connection.execute("INSERT INTO phone_verifications (user_id, code_hash, expires_at).await ($1, $2, $3::TIMESTAMPTZ).await \
                        ON CONFLICT (user_id) DO UPDATE SET code_hash = EXCLUDED.code_hash, expires_at = EXCLUDED.expires_at, attempts = 0",
        &[ParameterValue::Str(user_id.clone()), ParameterValue::Str(code_hash), ParameterValue::Str(expires_at)]).await?;

    let account_sid = variables::get("twilio_account_sid").await?;
    let auth_token_enc = variables::get("twilio_auth_token_encrypted").await?;
    let auth_token = decrypt_token(&auth_token_enc).await?;
    let from_phone = variables::get("twilio_from_number").await?;

    send_twilio_sms(&account_sid, &auth_token, &from_phone, &verify_req.phone_number, &format!("Mecris code: {}", code)).await?;

    json_response(200, &"Verification code sent")
}

async fn handle_confirm_phone_verification_post(req: Request) -> anyhow::Result<Response<String>> {
    let auth_header = req.headers().get("authorization");
    let user_id = match extract_user_id(auth_header).await {
        Some(id) => id,
        None => return Ok(text_response(401, "Unauthorized")?),
    };

    let body_bytes = req.into_body().collect().await.map_err(|e| anyhow::anyhow!("Body err: {:?}", e))?.to_bytes();
    #[derive(Deserialize)]
    struct VerificationConfirmRequest { code: String }
    let confirm_req: VerificationConfirmRequest = serde_json::from_slice(&body_bytes)?;
    
    let db_url = match variables::get("db_url").await {
        Ok(v) if !v.is_empty() => v,
        _ => variables::get("neon_db_url").await?,
    };
    let connection = Connection::open(&db_url).await?;

    let rs = connection.query("SELECT code_hash, CAST(EXTRACT(EPOCH FROM expires_at) AS BIGINT).await, attempts FROM phone_verifications WHERE user_id = $1",
        &[ParameterValue::Str(user_id.clone())]).await?;
    let rows = rs.collect().await?;
    
    if rows.is_empty() { return Ok(text_response(400, "No request found")?); }

    let db_hash = match &rows[0][0] { DbValue::Str(s) => s, _ => "" };
    let expires_epoch = match &rows[0][1] { DbValue::Int64(i) => *i as u64, _ => 0 };
    let attempts = match &rows[0][2] { DbValue::Int32(i) => *i, _ => 0 };

    if attempts >= 5 { return Ok(text_response(429, "Too many attempts")?); }
    if chrono::Utc::now().timestamp() as u64 > expires_epoch { return Ok(text_response(400, "Code expired")?); }

    let input_hash = hex::encode(Sha256::digest(confirm_req.code.as_bytes()));
    if input_hash == db_hash {
        connection.execute("UPDATE users SET phone_verified = true WHERE pocket_id_sub = $1", &[ParameterValue::Str(user_id.clone())]).await?;
        connection.execute("DELETE FROM phone_verifications WHERE user_id = $1", &[ParameterValue::Str(user_id.clone())]).await?;
        json_response(200, &"Phone verified")
    } else {
        connection.execute("UPDATE phone_verifications SET attempts = attempts + 1 WHERE user_id = $1", &[ParameterValue::Str(user_id.clone())]).await?;
        text_response(400, "Invalid code")
    }
}

async fn handle_twilio_webhook_post(req: Request) -> anyhow::Result<Response<String>> {
    let auth_token_enc = match variables::get("twilio_auth_token_encrypted").await {
        Ok(s) if !s.is_empty() => s,
        _ => return Ok(text_response(503, "twilio_auth_token_encrypted not configured")?),
    };
    let auth_token = decrypt_token(&auth_token_enc).await?;
    
    let body_bytes = req.into_body().collect().await.map_err(|e| anyhow::anyhow!("Body err: {:?}", e))?.to_bytes();
    let body_str = std::str::from_utf8(&body_bytes).unwrap_or("");
    let params = parse_form_body(body_str);
    let from_num = params.get("From").map(|s| s.as_str()).unwrap_or("");
    let body_text = params.get("Body").map(|s| s.to_uppercase()).unwrap_or_default();

    if body_text.contains("YES") {
        let db_url = match variables::get("db_url").await {
            Ok(v) if !v.is_empty() => v,
            _ => variables::get("neon_db_url").await?,
        };
        let connection = Connection::open(&db_url).await?;
        let rs = connection.query("SELECT pocket_id_sub, phone_number_encrypted, beeminder_goal FROM users WHERE phone_number_encrypted IS NOT NULL", &[]).await?;
        let rows = rs.collect().await?;
        
        for row in &rows {
            let user_id = match &row[0] { DbValue::Str(s) => s.clone(), _ => continue };
            let phone_enc = match &row[1] { DbValue::Str(s) => s.clone(), _ => continue };
            let goal = match &row[2] { DbValue::Str(s) => s.clone(), _ => "bike".to_string() };
            
            if let Ok(phone) = decrypt_token(&phone_enc).await {
                if phones_match(&phone, from_num) {
                    let _ = push_to_beeminder(&user_id, &goal, 1.0, "Walk logged via SMS", &connection).await;
                    let _ = connection.execute("INSERT INTO message_log (user_id, type, sent_at, compliance_status) ($1, 'walk_ack', CURRENT_TIMESTAMP, 'received').await", &[ParameterValue::Str(user_id)]).await;
                }
            }
        }
    }

    Ok(Response::builder().status(200).header("content-type", "text/xml").body(r#"<?xml version="1.0" encoding="UTF-8"?><Response></Response>"#.to_string())?)
}

// --- Placeholder logic for remaining helper functions (pure/tested elsewhere) ---

fn parse_form_body(body: &str) -> HashMap<String, String> {
    body.split('&').filter_map(|s| {
        let mut parts = s.splitn(2, '=');
        let key = urlencoding::decode(parts.next()?).ok()?;
        let val = urlencoding::decode(parts.next().unwrap_or("")).ok()?;
        Some((key.into_owned(), val.into_owned()))
    }).collect()
}

fn phones_match(p1: &str, p2: &str) -> bool {
    let clean = |s: &str| s.chars().filter(|c| c.is_digit(10)).collect::<String>();
    let c1 = clean(p1);
    let c2 = clean(p2);
    !c1.is_empty() && c1 == c2
}

