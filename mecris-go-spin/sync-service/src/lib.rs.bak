async fn handle_languages_get(req: Request) -> anyhow::Result<Response<String>> {
    let auth_header = req.headers().get("authorization");
    let user_id = match extract_user_id(auth_header).await {
        Some(id) => id,
        None => return Ok(text_response(401, "Unauthorized")?),
    };

    let db_url = match variables::get("db_url").await {
        Ok(v) if !v.is_empty() => v,
        _ => variables::get("neon_db_url").await?,
    };
    let connection = Connection::open(&db_url).await?;
    
    let query = "SELECT language_name, current_reviews, tomorrow_reviews, next_7_days_reviews, daily_rate::FLOAT8, safebuf, derail_risk, pump_multiplier::FLOAT8, beeminder_slug, daily_completions FROM language_stats WHERE user_id = $1";
    let rs = connection.query(query, &[ParameterValue::Str(user_id)]).await?;
    let rows = rs.collect().await?;

    #[derive(Serialize)]
    struct LanguageStat {
        name: String,
        current: i32,
        tomorrow: i32,
        next_7: i32,
        rate: f64,
        safebuf: i32,
        risk: String,
        multiplier: f64,
        slug: String,
        daily_done: i32,
    }

    let mut languages = Vec::new();
    for row in &rows {
        languages.push(LanguageStat {
            name: match &row[0] { DbValue::Str(s) => s.clone(), _ => continue },
            current: match &row[1] { DbValue::Int32(i) => *i, _ => 0 },
            tomorrow: match &row[2] { DbValue::Int32(i) => *i, _ => 0 },
            next_7: match &row[3] { DbValue::Int32(i) => *i, _ => 0 },
            rate: match &row[4] { DbValue::Floating64(f) => *f, _ => 0.0 },
            safebuf: match &row[5] { DbValue::Int32(i) => *i, _ => 0 },
            risk: match &row[6] { DbValue::Str(s) => s.clone(), _ => "unknown".to_string() },
            multiplier: match &row[7] { DbValue::Floating64(f) => *f, _ => 1.0 },
            slug: match &row[8] { DbValue::Str(s) => s.clone(), _ => "none".to_string() },
            daily_done: match &row[9] { DbValue::Int32(i) => *i, _ => 0 },
        });
    }

    #[derive(Serialize)]
    struct LanguagesResponse {
        languages: Vec<LanguageStat>,
    }

    let resp = LanguagesResponse { languages };
    json_response(200, &resp)
}

