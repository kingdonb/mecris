use aes_gcm::{
    aead::{Aead, KeyInit},
    Aes256Gcm, Nonce
};

async fn decrypt_token(encrypted_hex: &str) -> anyhow::Result<String> {
    let key_str = variables::get("master_encryption_key").await
        .map_err(|e| anyhow::anyhow!("Failed to get master_encryption_key: {:?}", e))?;
    let key_str = key_str.trim();
    let key_bytes = hex::decode(&key_str)
        .map_err(|e| anyhow::anyhow!("Hex decode failed for master_encryption_key (len={}): {}", key_str.len(), e))?;
    let cipher = Aes256Gcm::new_from_slice(&key_bytes)?;

    let encrypted_hex = encrypted_hex.trim();
    let encrypted_bytes = hex::decode(encrypted_hex)
        .map_err(|e| anyhow::anyhow!("Hex decode failed for encrypted data (len={}): {}", encrypted_hex.len(), e))?;
    if encrypted_bytes.len() < 12 {
        return Err(anyhow::anyhow!("Invalid encrypted token length"));
    }

    let nonce = Nonce::from_slice(&encrypted_bytes[..12]);
    let ciphertext = &encrypted_bytes[12..];

    let decrypted_bytes = cipher.decrypt(nonce, ciphertext)
        .map_err(|e| anyhow::anyhow!("Decryption failed: {:?}", e))?;

    Ok(String::from_utf8(decrypted_bytes)?)
}

async fn encrypt_token(plaintext: &str) -> anyhow::Result<String> {
    let key_str = variables::get("master_encryption_key").await
        .map_err(|e| anyhow::anyhow!("Failed to get master_encryption_key: {:?}", e))?;
    let key_str = key_str.trim();
    let key_bytes = hex::decode(&key_str)
        .map_err(|e| anyhow::anyhow!("Hex decode failed for master_encryption_key: {}", e))?;
    let cipher = Aes256Gcm::new_from_slice(&key_bytes)?;

    let mut nonce_bytes = [0u8; 12];
    use getrandom::getrandom;
    getrandom(&mut nonce_bytes).map_err(|e| anyhow::anyhow!("getrandom failed: {}", e))?;
    let nonce = Nonce::from_slice(&nonce_bytes);

    let ciphertext = cipher.encrypt(nonce, plaintext.as_bytes())
        .map_err(|e| anyhow::anyhow!("Encryption failed: {:?}", e))?;

    let mut combined = nonce_bytes.to_vec();
    combined.extend_from_slice(&ciphertext);
    Ok(hex::encode(combined))
}

async fn extract_user_id(auth_header: Option<&spin_sdk::http::HeaderValue>) -> Option<String> {
    if let Ok(bypass) = variables::get("auth_bypass").await {
        if bypass == "true" {
            if let Some(h) = auth_header {
                if let Ok(val) = std::str::from_utf8(h.as_ref()) {
                    if val.starts_with("TestUser ") {
                        return Some(val[9..].to_string());
                    }
                }
            }
        }
    }

    let header_val = std::str::from_utf8(auth_header?.as_ref()).ok()?;
    if !header_val.starts_with("Bearer ") {
        return None;
    }
    let token = &header_val[7..];

    let jwks = get_jwks().await.ok()?;

    let parts: Vec<&str> = token.split('.').collect();
    if parts.len() != 3 { return None; }
    let header_bytes = URL_SAFE_NO_PAD.decode(parts[0]).ok()?;
    let header: serde_json::Value = serde_json::from_slice(&header_bytes).ok()?;
    let kid = header["kid"].as_str()?;

    let jwk = jwks.keys.iter().find(|k| k.kid == kid)?;

    if jwk.kty == "EC" && jwk.alg == "ES384" {
        let n_bytes = URL_SAFE_NO_PAD.decode(&jwk.n).ok()?;
        let e_bytes = URL_SAFE_NO_PAD.decode(&jwk.e).ok()?;
        
        let mut public_key_bytes = vec![0x04];
        public_key_bytes.extend_from_slice(&n_bytes);
        public_key_bytes.extend_from_slice(&e_bytes);

        let public_key = ES384PublicKey::from_bytes(&public_key_bytes).ok()?;
        
        let options = VerificationOptions {
            accept_future: true,
            ..Default::default()
        };
        
        match public_key.verify_token::<serde_json::Value>(token, Some(options)) {
            Ok(claims) => {
                return claims.custom["sub"].as_str().map(|s| s.to_string());
            }
            Err(e) => {
                eprintln!("JWT VERIFY ERROR: {:?}", e);
                return None;
            }
        }
    }

    None
}

async fn cloud_role() -> String {
    let provider = match variables::get("cloud_provider").await {
        Ok(p) => p,
        _ => "unknown_cloud".to_string(),
    };
    match provider.as_str() {
        "akamai" => "akamai_functions".to_string(),
        "fermyon" => "fermyon_cloud".to_string(),
        _ => "unknown_cloud".to_string(),
    }
}

fn obs_status_query() -> &'static str {
    "INSERT INTO scheduler_election (user_id, role, last_status, intent, last_error, heartbeat) \
     VALUES ($1, $2, $3, $4, $5, CURRENT_TIMESTAMP) \
     ON CONFLICT (user_id, role) DO UPDATE SET \
     last_status = EXCLUDED.last_status, intent = EXCLUDED.intent, last_error = EXCLUDED.last_error, heartbeat = EXCLUDED.heartbeat"
}

async fn write_obs_status(
    connection: &Connection,
    user_id: &str,
    role: &str,
    last_status: &str,
    intent: &str,
    last_error: Option<&str>,
) {
    let error_param = match last_error {
        Some(e) => ParameterValue::Str(e.to_string()),
        None => ParameterValue::DbNull,
    };
    if let Err(e) = connection.execute(obs_status_query(), &[
        ParameterValue::Str(user_id.to_string()),
        ParameterValue::Str(role.to_string()),
        ParameterValue::Str(last_status.to_string()),
        ParameterValue::Str(intent.to_string()),
        error_param,
    ]).await {
        println!("[DEBUG] write_obs_status: UPDATE failed (columns may be absent): {}", e);
    }
}

async fn register_cloud_heartbeat(connection: &Connection, user_id: &str) -> anyhow::Result<()> {
    let provider = match variables::get("cloud_provider").await {
        Ok(p) => p,
        _ => "unknown_cloud".to_string(),
    };
    let role = cloud_role().await;

    println!("REGISTERING HEARTBEAT: user={} role={} provider={}", user_id, role, provider);

    let query = "INSERT INTO scheduler_election (user_id, role, process_id, heartbeat) \
                 VALUES ($1, $2, $3, CURRENT_TIMESTAMP) \
                 ON CONFLICT (user_id, role) DO UPDATE SET \
                 heartbeat = EXCLUDED.heartbeat, process_id = EXCLUDED.process_id";

    connection.execute(query, &[
        ParameterValue::Str(user_id.to_string()),
        ParameterValue::Str(role.to_string()),
        ParameterValue::Str(provider.to_string()),
    ]).await?;

    Ok(())
}

#[http_service]
async fn handle_sync_service(req: Request) -> anyhow::Result<Response<String>> {
    let path = req.uri().path();
    let method = req.method();
    println!("REQUEST: {} {}", method, path);
    
    if method == &Method::OPTIONS {
        return Ok(Response::builder()
            .status(204)
            .header("access-control-allow-origin", "*")
            .header("access-control-allow-methods", "GET, POST, PATCH, OPTIONS")
            .header("access-control-allow-headers", "authorization, content-type, x-internal-api-key")
            .body(String::new())?);
    }

    let response = if path == "/walks" {
        if method != &Method::POST {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_walks_post(req).await?
        }
    } else if path == "/budget" {
        if method != &Method::GET {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_budget_get(req).await?
        }
    } else if path == "/languages" {
        if method != &Method::GET {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_languages_get(req).await?
        }
    } else if path == "/languages/multiplier" {
        if method != &Method::POST {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_multiplier_post(req).await?
        }
    } else if path == "/health" {
        handle_health_get(req).await?
    } else if path == "/heartbeat" {
        if method != &Method::POST {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_heartbeat_post(req).await?
        }
    } else if path == "/internal/cloud-sync" {
        if method != &Method::POST {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_cloud_sync(req).await?
        }
    } else if path == "/aggregate-status" {
        if method != &Method::GET {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_aggregate_status_get(req).await?
        }
    } else if path == "/profile" {
        if method == &Method::POST {
            handle_profile_post(req).await?
        } else if method == &Method::GET {
            handle_profile_get(req).await?
        } else {
            text_response(405, "Method Not Allowed")?
        }
    } else if path == "/internal/trigger-reminders" {
        if method != &Method::POST && method != &Method::GET {
            text_response(405, "Method Not Allowed")?
        } else {
            let configured_key = match variables::get("internal_api_key").await {
                Ok(v) => v,
                _ => String::new(),
            };
            let provided_key = req.headers().get("x-internal-api-key").and_then(|v| v.to_str().ok());
            if !internal_api_key_ok(&configured_key, provided_key) {
                text_response(401, "Unauthorized")?
            } else {
                handle_trigger_reminders_post(req).await?
            }
        }
    } else if path == "/internal/failover-sync" {
        if method != &Method::POST && method != &Method::GET {
            text_response(405, "Method Not Allowed")?
        } else {
            let configured_key = match variables::get("internal_api_key").await {
                Ok(v) => v,
                _ => String::new(),
            };
            let provided_key = req.headers().get("x-internal-api-key").and_then(|v| v.to_str().ok());
            if !internal_api_key_ok(&configured_key, provided_key) {
                text_response(401, "Unauthorized")?
            } else {
                handle_failover_sync_post(req).await?
            }
        }
    } else if path == "/internal/weather-heuristic" {
        if method != &Method::GET {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_weather_heuristic_get(req).await?
        }
    } else if path == "/internal/request-phone-verification" {
        if method != &Method::POST {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_request_phone_verification_post(req).await?
        }
    } else if path == "/internal/confirm-phone-verification" {
        if method != &Method::POST {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_confirm_phone_verification_post(req).await?
        }
    } else if path == "/internal/twilio-webhook" {
        if method != &Method::POST {
            text_response(405, "Method Not Allowed")?
        } else {
            handle_twilio_webhook_post(req).await?
        }
    } else {
        text_response(404, "Not Found")?
    };

    Ok(add_cors(response))
}

fn get_modality_status_string(role: &str, mins: u64) -> &'static str {
    match role {
        "leader" => if mins < 2 { "healthy" } else if mins < 5 { "degraded" } else { "offline" },
        "android_client" => if mins < 20 { "healthy" } else if mins < 60 { "degraded" } else { "offline" },
        "akamai_functions" => if mins < 135 { "healthy" } else if mins < 250 { "degraded" } else { "offline" },
        "fermyon_cloud" => if mins < 5 { "healthy" } else if mins < 15 { "degraded" } else { "offline" },
        _ => "unknown",
    }
}

async fn handle_aggregate_status_get(req: Request) -> anyhow::Result<Response<String>> {
    let auth_header = req.headers().get("authorization");
    let user_id = match extract_user_id(auth_header).await {
        Some(id) => id,
        None => return Ok(text_response(401, "Unauthorized")?),
    };

    let full = req.uri().query().map(|q| q.contains("full=true")).unwrap_or(false);

    let db_url = match variables::get("db_url").await {
        Ok(v) if !v.is_empty() => v,
        _ => variables::get("neon_db_url").await?,
    };
    let connection = Connection::open(&db_url).await?;

    let walk_query = r#"
        SELECT COUNT(*) FROM walk_inferences 
        WHERE (start_time::TIMESTAMPTZ AT TIME ZONE 'US/Eastern')::DATE = (CURRENT_TIMESTAMP AT TIME ZONE 'US/Eastern')::DATE
        AND CAST(step_count AS INTEGER) >= 2000
        AND user_id = $1
    "#;
    let walk_rs = connection.query(walk_query, &[ParameterValue::Str(user_id.clone())]).await?;
    let walk_rows = walk_rs.collect().await?;
    let has_walked = if !walk_rows.is_empty() {
        match &walk_rows[0][0] { DbValue::Int64(i) => *i > 0, _ => false }
    } else {
        false
    };

    let lang_query = "SELECT language_name, current_reviews, tomorrow_reviews, pump_multiplier::FLOAT8, daily_completions FROM language_stats WHERE user_id = $1";
    let lang_rs = connection.query(lang_query, &[ParameterValue::Str(user_id.clone())]).await?;
    let lang_rows = lang_rs.collect().await?;

    let user_query = "SELECT vacation_mode_until::TEXT, phone_verified FROM users WHERE pocket_id_sub = $1";
    let user_rs = connection.query(user_query, &[ParameterValue::Str(user_id.clone())]).await?;
    let user_rows = user_rs.collect().await?;
    
    let (vacation_mode_until, phone_verified) = if !user_rows.is_empty() {
        let v = match &user_rows[0][0] { DbValue::Str(s) => Some(s.clone()), _ => None };
        let p = match &user_rows[0][1] { DbValue::Boolean(b) => *b, _ => false };
        (v, p)
    } else {
        (None, false)
    };

    let mut all_clear = has_walked;
    let mut stats = Vec::new();

    #[derive(Serialize)]
    struct LanguageStatBrief {
        name: String,
        daily_completions: i32,
        absolute_target: i32,
        goal_met: bool,
    }

    for row in &lang_rows {
        let name = match &row[0] { DbValue::Str(s) => s.clone(), _ => continue };
        let current = match &row[1] { DbValue::Int32(i) => *i, _ => 0 };
        let tomorrow = match &row[2] { DbValue::Int32(i) => *i, _ => 0 };
        let multiplier = match &row[3] { 
            DbValue::Floating64(f) => *f,
            DbValue::Floating32(f) => *f as f64,
            _ => 1.0 
        };
        let daily_done = match &row[4] { DbValue::Int32(i) => *i, _ => 0 };

        let (abs_target, _, goal_met) = calculate_review_pump_targets(current, tomorrow, multiplier, daily_done);
        
        if !goal_met { all_clear = false; }

        stats.push(LanguageStatBrief {
            name,
            daily_completions: daily_done,
            absolute_target: abs_target,
            goal_met,
        });
    }

    if vacation_mode_until.is_some() {
        all_clear = true;
    }

    #[derive(Serialize)]
    struct ModalityStatus {
        role: String,
        status: String,
        last_seen: String,
    }

    #[derive(Serialize)]
    struct AggregateStatusResponse {
        all_clear: bool,
        walk_complete: bool,
        phone_verified: bool,
        languages: Vec<LanguageStatBrief>,
        modalities: Option<Vec<ModalityStatus>>,
    }

    let mut modalities = None;
    if full {
        let pulse_query = "SELECT role, heartbeat::TEXT, CAST(EXTRACT(EPOCH FROM (CURRENT_TIMESTAMP - heartbeat)) / 60 AS BIGINT) AS minutes_since \
                           FROM scheduler_election WHERE user_id = $1 OR user_id IS NULL \
                           ORDER BY heartbeat DESC";
        let pulse_rs = connection.query(pulse_query, &[ParameterValue::Str(user_id.clone())]).await?;
        let pulse_rows = pulse_rs.collect().await?;
        
        let mut mods = Vec::new();
        for row in &pulse_rows {
            let db_role = match &row[0] { DbValue::Str(s) => s.clone(), _ => continue };
            let display_role = match db_role.as_str() {
                "leader" => "MCP SERVER",
                "android_client" => "ANDROID",
                "akamai_functions" => "AKAMAI",
                "fermyon_cloud" => "FERMYON",
                _ => &db_role,
            };

            let last_seen = match &row[1] { DbValue::Str(s) => s.clone(), _ => "never".to_string() };
            let mins = match &row[2] { 
                DbValue::Int64(i) => *i as u64,
                DbValue::Int32(i) => *i as u64,
                _ => 9999 
            };

            mods.push(ModalityStatus {
                role: display_role.to_string(),
                status: get_modality_status_string(&db_role, mins).to_string(),
                last_seen,
            });
        }
        modalities = Some(mods);
    }

    let resp = AggregateStatusResponse {
        all_clear,
        walk_complete: has_walked,
        phone_verified,
        languages: stats,
        modalities,
    };
    json_response(200, &resp)
}

fn calculate_review_pump_targets(current: i32, tomorrow: i32, multiplier: f64, daily_done: i32) -> (i32, f64, bool) {
    let target_flow_rate = if multiplier > 0.0 { multiplier } else { 1.0 };
    let total_pending = current + tomorrow;
    let absolute_target = if total_pending > 0 {
        (total_pending as f64 / target_flow_rate).ceil() as i32
    } else {
        0
    };
    let goal_met = daily_done >= absolute_target;
    (absolute_target, target_flow_rate, goal_met)
}

async fn handle_profile_post(req: Request) -> anyhow::Result<Response<String>> {
    let auth_header = req.headers().get("authorization");
    let user_id = match extract_user_id(auth_header).await {
        Some(id) => id,
        None => return Ok(text_response(401, "Unauthorized")?),
    };

    let body = req.into_body().collect().await.map_err(|e| anyhow::anyhow!("Body err: {:?}", e))?.to_bytes();
    
    #[derive(Deserialize)]
    struct ProfileRequest {
        phone_number: Option<String>,
        beeminder_user: Option<String>,
        latitude: Option<f64>,
        longitude: Option<f64>,
        vacation_mode: Option<bool>,
        autonomous_sync_enabled: Option<bool>,
        notification_prefs: Option<serde_json::Value>,
    }

    let profile_req: ProfileRequest = match serde_json::from_slice(&body) {
        Ok(r) => r,
        Err(e) => return Ok(text_response(400, &format!("Invalid JSON: {}", e))?),
    };

    let db_url = match variables::get("db_url").await {
        Ok(v) if !v.is_empty() => v,
        _ => variables::get("neon_db_url").await?,
    };
    let connection = Connection::open(&db_url).await?;

    if let Some(phone) = &profile_req.phone_number {
        let phone_enc = encrypt_token(phone).await?;
        connection.execute("UPDATE users SET phone_number_encrypted = $1, phone_verified = FALSE WHERE pocket_id_sub = $2", 
            &[ParameterValue::Str(phone_enc), ParameterValue::Str(user_id.clone())]).await?;
    }

    if let Some(bu) = &profile_req.beeminder_user {
        let bu_enc = encrypt_token(bu).await?;
        connection.execute("UPDATE users SET beeminder_user_encrypted = $1 WHERE pocket_id_sub = $2", 
            &[ParameterValue::Str(bu_enc), ParameterValue::Str(user_id.clone())]).await?;
    }

    if let Some(lat) = profile_req.latitude {
        connection.execute("UPDATE users SET location_lat = $1 WHERE pocket_id_sub = $2", 
            &[ParameterValue::Floating64(lat), ParameterValue::Str(user_id.clone())]).await?;
    }

    if let Some(lon) = profile_req.longitude {
        connection.execute("UPDATE users SET location_lon = $1 WHERE pocket_id_sub = $2", 
            &[ParameterValue::Floating64(lon), ParameterValue::Str(user_id.clone())]).await?;
    }

    if let Some(vacation) = profile_req.vacation_mode {
        if !vacation {
            connection.execute("UPDATE users SET vacation_mode_until = NULL WHERE pocket_id_sub = $1", 
                &[ParameterValue::Str(user_id.clone())]).await?;
        } else {
            let until = (chrono::Utc::now() + chrono::Duration::days(1)).to_rfc3339();
            connection.execute("UPDATE users SET vacation_mode_until = $1::TIMESTAMPTZ WHERE pocket_id_sub = $2", 
                &[ParameterValue::Str(until), ParameterValue::Str(user_id.clone())]).await?;
        }
    }

    if let Some(auto_sync) = profile_req.autonomous_sync_enabled {
        connection.execute("UPDATE users SET autonomous_sync_enabled = $1 WHERE pocket_id_sub = $2", 
            &[ParameterValue::Boolean(auto_sync), ParameterValue::Str(user_id.clone())]).await?;
    }

    if let Some(prefs) = &profile_req.notification_prefs {
        connection.execute("UPDATE users SET notification_prefs = $1::JSONB WHERE pocket_id_sub = $2", 
            &[ParameterValue::Str(serde_json::to_string(prefs)?), ParameterValue::Str(user_id.clone())]).await?;
    }

    Ok(text_response(200, r#"{"status":"success","message":"Profile updated"}"#)?)
}

async fn handle_profile_get(req: Request) -> anyhow::Result<Response<String>> {
    let auth_header = req.headers().get("authorization");
    let user_id = match extract_user_id(auth_header).await {
        Some(id) => id,
        None => return Ok(text_response(401, "Unauthorized")?),
    };

    let db_url = match variables::get("db_url").await {
        Ok(v) if !v.is_empty() => v,
        _ => variables::get("neon_db_url").await?,
    };
    let connection = Connection::open(&db_url).await?;

    let query = "SELECT phone_number_encrypted, beeminder_user_encrypted, location_lat, location_lon, \
                 vacation_mode_until::TEXT, autonomous_sync_enabled, \
                 COALESCE(notification_prefs::TEXT, '') \
                 FROM users WHERE pocket_id_sub = $1";
    let rs = connection.query(query, &[ParameterValue::Str(user_id.clone())]).await?;
    let rows = rs.collect().await?;

    if rows.is_empty() {
        return Ok(text_response(404, "User not found")?);
    }

    #[derive(Serialize)]
    struct ProfileResponse {
        phone_number_configured: bool,
        beeminder_user_configured: bool,
        latitude: Option<f64>,
        longitude: Option<f64>,
        vacation_mode_until: Option<String>,
        autonomous_sync_enabled: bool,
        notification_prefs: Option<serde_json::Value>,
    }

    let row = &rows[0];
    let resp = ProfileResponse {
        phone_number_configured: match &row[0] { DbValue::Str(s) => !s.is_empty(), _ => false },
        beeminder_user_configured: match &row[1] { DbValue::Str(s) => !s.is_empty(), _ => false },
        latitude: match &row[2] { DbValue::Floating64(f) => Some(*f), _ => None },
        longitude: match &row[3] { DbValue::Floating64(f) => Some(*f), _ => None },
        vacation_mode_until: match &row[4] { DbValue::Str(s) if !s.is_empty() => Some(s.clone()), _ => None },
        autonomous_sync_enabled: match &row[5] { DbValue::Boolean(b) => *b, _ => false },
        notification_prefs: match &row[6] { 
            DbValue::Str(s) if !s.is_empty() => serde_json::from_str(s).ok(),
            _ => None 
        },
    };

    json_response(200, &resp)
}

