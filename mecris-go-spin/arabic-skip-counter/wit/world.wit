package mecris:arabic-skip-counter@0.1.0;

/// Arabic skip counter WASM component.
/// Counts consecutive ignored Arabic review cycles by querying the Neon
/// message_log via the Neon HTTP API (/sql endpoint).
/// Used as the skip_count_provider for ReminderService Phase 3 escalation.
world arabic-skip-counter {
  /// Count Arabic reminder messages sent to user-id in the last `hours` hours.
  ///
  /// Queries message_log for arabic_review_reminder and arabic_review_escalation
  /// rows. Returns the count as a u32. Returns 0 on any HTTP/parse error.
  ///
  /// Parameters:
  ///   neon-url  — postgres:// URL (HTTP endpoint derived from it)
  ///   user-id   — the user identifier (e.g. "yebyen")
  ///   hours     — lookback window in hours (default: 24)
  export count-arabic-reminders: func(neon-url: string, user-id: string, hours: u32) -> u32;
}
